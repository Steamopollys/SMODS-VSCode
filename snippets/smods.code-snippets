  "SMODS Consumable (Planet)": {
    "prefix": "smods-consumable-planet",
    "description": "SMODS.Consumable of set 'Planet' that upgrades a poker hand",
    "body": [
      "SMODS.Consumable {",
      "    key = '${1:my_planet}',",
      "    set = 'Planet',",
      "    loc_txt = {",
      "        name = '${2:Planet Name}',",
      "        text = {",
      "            '{C:attention}Levels up{} {C:legendary,E:1}#1#{}',",
      "            'Currently level {C:mult}#2#{}'",
      "        }",
      "    },",
      "    config = { hand_type = '${3:High Card}' },",
      "    atlas = '${4:consumables}',",
      "    pos = { x = ${5:0}, y = ${6:0} },",
      "    cost = 3,",
      "    loc_vars = function(self, info_queue, card)",
      "        return { vars = { G.GAME.hands[self.config.hand_type].level } }",
      "    end,",
      "    use = function(self, card, area, copier)",
      "        update_hand_text({ sound = 'button', volume = 0.7, pitch = 0.8, delay = 0.3 }, {",
      "            handname = localize(self.config.hand_type, 'poker_hands'),",
      "            chips = G.GAME.hands[self.config.hand_type].chips,",
      "            mult = G.GAME.hands[self.config.hand_type].mult,",
      "            level = G.GAME.hands[self.config.hand_type].level",
      "        })",
      "        level_up_hand(card, self.config.hand_type)",
      "    end",
      "}"
    ]
  },

