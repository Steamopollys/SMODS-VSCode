  "SMODS Joker": {
    "prefix": "smods-joker",
    "description": "SMODS.Joker definition with calculate function",
    "body": [
      "SMODS.Joker {",
      "    key = '${1:my_joker}',",
      "    loc_txt = {",
      "        name = '${2:Joker Name}',",
      "        text = {",
      "            '${3:{C:mult}+#1#{} Mult}'",
      "        }",
      "    },",
      "    config = { extra = { ${4:mult = 4} } },",
      "    rarity = ${5|1,2,3,4|},",
      "    atlas = '${6:jokers}',",
      "    pos = { x = ${7:0}, y = ${8:0} },",
      "    cost = ${9:4},",
      "    blueprint_compat = ${10|true,false|},",
      "    eternal_compat  = ${11|true,false|},",
      "    loc_vars = function(self, info_queue, card)",
      "        return { vars = { ${12:card.ability.extra.mult} } }",
      "    end,",
      "    calculate = function(self, card, context)",
      "        if context.joker_main then",
      "            return {",
      "                mult = card.ability.extra.mult,",
      "                message = localize { type = 'variable', key = 'a_mult', vars = { card.ability.extra.mult } }",
      "            }",
      "        end",
      "        $0",
      "    end",
      "}"
    ]
  },

