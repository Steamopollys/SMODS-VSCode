{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smods.dev/lovely-patches.schema.json",
  "title": "Lovely Patch File",
  "description": "Lovely-Injector patches.toml manifest. See https://github.com/ethangreen-dev/lovely-injector",
  "type": "object",
  "properties": {
    "manifest": {
      "type": "object",
      "description": "Top-level metadata for this patch bundle.",
      "properties": {
        "version": {
          "type": "string",
          "description": "Patch format version. Typically \"1.0.0\"."
        },
        "dump_lua": {
          "type": "boolean",
          "description": "Write patched Lua output to disk for debugging.",
          "default": false
        },
        "priority": {
          "type": "integer",
          "description": "Load priority (lower runs first). Ties break alphabetically."
        }
      },
      "additionalProperties": false
    },
    "variables": {
      "type": "object",
      "description": "String variables substitutable inside payloads via {{variable}}.",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "patches": {
      "type": "array",
      "description": "Individual patch definitions.",
      "items": { "$ref": "#/definitions/patch" }
    }
  },
  "definitions": {
    "patch": {
      "type": "object",
      "oneOf": [
        { "required": ["pattern"] },
        { "required": ["regex"] },
        { "required": ["copy"] },
        { "required": ["module"] }
      ],
      "properties": {
        "pattern": { "$ref": "#/definitions/patternPatch" },
        "regex":   { "$ref": "#/definitions/regexPatch" },
        "copy":    { "$ref": "#/definitions/copyPatch" },
        "module":  { "$ref": "#/definitions/modulePatch" }
      },
      "additionalProperties": false
    },
    "patternPatch": {
      "type": "object",
      "description": "Text-substitution patch using a literal pattern.",
      "required": ["target", "pattern", "position", "payload"],
      "properties": {
        "target": {
          "type": "string",
          "description": "File path inside the game's Lua tree (e.g. \"game.lua\", \"functions/common_events.lua\")."
        },
        "pattern": {
          "type": "string",
          "description": "Literal text to find. Supports * wildcards."
        },
        "position": {
          "type": "string",
          "enum": ["before", "after", "at"],
          "description": "Where to splice the payload relative to the pattern."
        },
        "payload": {
          "type": "string",
          "description": "Lua source to inject."
        },
        "match_indent": {
          "type": "boolean",
          "description": "Indent the payload to match the matched line's leading whitespace.",
          "default": false
        },
        "times": {
          "type": "integer",
          "description": "Maximum number of matches to patch. Omit for all.",
          "minimum": 1
        },
        "overwrite": {
          "type": "boolean",
          "description": "Overwrite the matched text (only valid with position = \"at\").",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "regexPatch": {
      "type": "object",
      "description": "Regex-based substitution. Capture groups can be referenced in `payload` via $1, $2, etc.",
      "required": ["target", "pattern", "position", "payload"],
      "properties": {
        "target":      { "type": "string" },
        "pattern":     { "type": "string", "description": "PCRE-style regex." },
        "position":    { "type": "string", "enum": ["before", "after", "at"] },
        "payload":     { "type": "string" },
        "match_indent":{ "type": "boolean", "default": false },
        "times":       { "type": "integer", "minimum": 1 },
        "line_prepend":{ "type": "string" }
      },
      "additionalProperties": false
    },
    "copyPatch": {
      "type": "object",
      "description": "Copy a Lua file into the patched tree at a given path.",
      "required": ["target", "sources"],
      "properties": {
        "target":  { "type": "string", "description": "Destination path inside the game tree." },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source files relative to this patch bundle."
        },
        "position": { "type": "string", "enum": ["prepend", "append", "overwrite"], "default": "append" }
      },
      "additionalProperties": false
    },
    "modulePatch": {
      "type": "object",
      "description": "Register a patch-bundle-relative file as a require()-able module.",
      "required": ["source", "name"],
      "properties": {
        "source": { "type": "string", "description": "Lua file relative to this patches.toml." },
        "name":   { "type": "string", "description": "Module name usable by require()." },
        "display_name": { "type": "string" },
        "priority": { "type": "integer" }
      },
      "additionalProperties": false
    }
  }
}
